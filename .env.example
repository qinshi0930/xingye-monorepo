# ========== 本地开发环境配置 ==========
# 用于混合开发模式：应用本地运行，基础设施容器化

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=xingye
POSTGRES_PASSWORD=
POSTGRES_DB=master_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# 数据库连接字符串 (由应用代码在容器中自动拼接，无需手动配置)
# 如需覆盖，可设置完整的 postgresql:// 连接字符串
# 格式：postgresql://username:password@host:port/database?sslmode=disable
DATABASE_URL=
