{
  "name": "xingye-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter web dev",
    "dev:web": "pnpm --filter web dev",
    "dev:admin": "pnpm --filter admin dev",
    "dev:api": "pnpm --filter api dev",
    "dev:all": "concurrently \"pnpm dev:web\" \"pnpm dev:admin\" \"pnpm dev:api\"",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:integration": "pnpm -r test:integration",
    "clean": "pnpm -r clean && rimraf node_modules",
    "db:generate": "pnpm -r db:generate",
    "db:push": "pnpm -r db:push",
    "db:migrate": "pnpm -r db:migrate",
    "db:studio": "pnpm -r db:studio",
    "infra:up": "podman-compose -f podman-compose.infra.yml up -d",
    "infra:down": "podman-compose -f podman-compose.infra.yml down",
    "infra:logs": "podman-compose -f podman-compose.infra.yml logs -f",
    "infra:reset": "podman-compose -f podman-compose.infra.yml down -v && rm -rf .infra-data/postgres/pgdata .infra-data/redis/*.aof .infra-data/redis/*.rdb",
    "ci:validate": "podman-compose -f podman-compose.ci.yml up --abort-on-container-exit",
    "ci:down": "podman-compose -f podman-compose.ci.yml down -v",
    "ci:logs": "podman-compose -f podman-compose.ci.yml logs -f",
    "validate": "./scripts/ci-validate.sh",
    "deploy": "./scripts/deploy.sh production",
    "deploy:fast": "./scripts/deploy.sh production true",
    "deploy:prod": "./scripts/deploy.sh production"
  },
  "devDependencies": {
    "@xingye/config-eslint": "workspace:*",
    "@xingye/config-typescript": "workspace:*",
    "concurrently": "^9.2.1",
    "rimraf": "^5.0.0",
    "typescript": "^5"
  }
}
